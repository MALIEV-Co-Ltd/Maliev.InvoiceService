{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore.Watch.BrowserRefresh": "None",
      "Microsoft.Hosting.Lifetime": "Information",
      "System": "Warning"
    }
  },
  "ConnectionStrings": {
    "InvoiceDbContext": "<connection-string-from-secrets>"
  },
  "Redis": {
    "Configuration": "<redis-connection-string-from-secrets>"
  },
  "ExternalServices": {
    "CurrencyService": {
      "BaseUrl": "<currency-service-url-from-config>"
    },
    "QuotationService": {
      "BaseUrl": "<quotation-service-url-from-config>"
    },
    "PaymentService": {
      "BaseUrl": "<payment-service-url-from-config>"
    },
    "PdfService": {
      "BaseUrl": "<pdf-service-url-from-config>"
    }
  },
  "RabbitMQ": {
    "Host": "<rabbitmq-host-from-config>",
    "Port": 5672,
    "Username": "<rabbitmq-username-from-secrets>",
    "Password": "<rabbitmq-password-from-secrets>"
  },
  "JwtSettings": {
    "PublicKeyBase64": "<jwt-public-key-from-secrets>"
  },
  "AllowedHosts": "*"
}