{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff}] [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}",
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "Maliev.InvoiceService"
    }
  },
  "ConnectionStrings": {
    "InvoiceDbContext": "<connection-string-from-secrets>"
  },
  "Redis": {
    "Configuration": "<redis-connection-string-from-secrets>"
  },
  "ExternalServices": {
    "CurrencyService": {
      "BaseUrl": "<currency-service-url-from-config>"
    },
    "QuotationService": {
      "BaseUrl": "<quotation-service-url-from-config>"
    },
    "PaymentService": {
      "BaseUrl": "<payment-service-url-from-config>"
    },
    "PdfService": {
      "BaseUrl": "<pdf-service-url-from-config>"
    }
  },
  "RabbitMQ": {
    "Host": "<rabbitmq-host-from-config>",
    "Port": 5672,
    "Username": "<rabbitmq-username-from-secrets>",
    "Password": "<rabbitmq-password-from-secrets>"
  },
  "JwtSettings": {
    "PublicKeyBase64": "<jwt-public-key-from-secrets>"
  },
  "AllowedHosts": "*"
}
